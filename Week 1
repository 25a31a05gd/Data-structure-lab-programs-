#include <iostream>
using namespace std;
int main() {
 char op;
 double num1, num2;
 cout << "Enter an operator (+, -, *, /): ";
 cin >> op; 
 cout << "Enter two operands: ";
 cin >> num1 >> num2; 
 switch (op) {case '+':
 cout << num1 << " + " << num2 << " = " << num1 + num2;
 break; 
 case '-':
 cout << num1 << " - " << num2 << " = " << num1 - num2;
 break;
 case '*':
 cout << num1 << " * " << num2 << " = " << num1 * num2;
 break;
 case '/':
 if (num2 != 0) { 
 cout << num1 << " / " << num2 << " = " << num1 / num2;
 } else {
 cout << "Error! Division by zero is not allowed.";
 }
 break;
 default:
 cout << "Error! The operator is not correct.";
 break;
 }
 cout << endl;return 0;
}

