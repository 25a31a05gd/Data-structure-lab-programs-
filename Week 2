PROGRAM 1 
#include <iostream>
using namespace std;
void swap_by_reference(int &a, int &b) {
 int temp;
 temp = a; 
 a = b; 
 b = temp; 
}
int main() {
 int x = 10, y = 20;
 cout << "Before swap: x = " << x << ", y = " << y << endl;
 swap_by_reference(x, y);
 cout << "After swap: x = " << x << ", y = " << y << endl;
 return 0;
}

PROGRAM 2 
#include <iostream>
using namespace std;
void swap_by_value(int a, int b) { int temp;
 temp = a; 
 a = b; 
 b = temp; 
 cout << "Inside function: a = " << a << ", b = " << b << endl;
}
int main() {
 int x = 10, y = 20;
 cout << "Before function call: x = " << x << ", y = " << y << endl;
 swap_by_value(x, y);
 cout << "After function call: x = " << x << ", y = " << y << endl;
 return 0;
}

